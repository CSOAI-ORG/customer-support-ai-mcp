{
  "name": "customer-support-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 \u0001",
  "version": "1.0.0",
  "tools": [
    {
      "name": "classify_ticket",
      "description": "Classify a support ticket by category, priority, and routing.",
      "parameters": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "customer_tier": {
            "type": "string"
          }
        },
        "required": [
          "subject",
          "body"
        ]
      }
    },
    {
      "name": "draft_response",
      "description": "Draft a customer support response based on ticket category.",
      "parameters": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string"
          },
          "customer_name": {
            "type": "string"
          },
          "issue_summary": {
            "type": "string"
          },
          "tone": {
            "type": "string"
          },
          "include_steps": {
            "type": "boolean"
          }
        },
        "required": [
          "category"
        ]
      }
    },
    {
      "name": "analyze_sentiment",
      "description": "Analyze customer message sentiment to gauge satisfaction.",
      "parameters": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array"
          }
        },
        "required": [
          "messages"
        ]
      }
    },
    {
      "name": "detect_escalation",
      "description": "Detect if a support ticket needs escalation to management.",
      "parameters": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array"
          },
          "ticket_age_hours": {
            "type": "number"
          },
          "response_count": {
            "type": "integer"
          },
          "customer_tier": {
            "type": "string"
          }
        },
        "required": [
          "messages"
        ]
      }
    },
    {
      "name": "generate_faq",
      "description": "Generate FAQ entries from common support ticket patterns.",
      "parameters": {
        "type": "object",
        "properties": {
          "tickets": {
            "type": "array"
          },
          "max_faqs": {
            "type": "integer"
          }
        },
        "required": [
          "tickets"
        ]
      }
    }
  ]
}